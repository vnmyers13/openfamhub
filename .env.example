# OpenFamHub Environment Configuration
# Copy this file to .env and fill in your values.

# Family display name
FAMILY_NAME=My Family

# IANA timezone (find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York

# 64-char hex secret key. Generate with: openssl rand -hex 32
# BACK THIS UP in a password manager — losing it breaks JWT tokens and encrypted data.
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX

# Database connection string (SQLite via aiosqlite)
DATABASE_URL=sqlite+aiosqlite:////data/db/homehub.db

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://homehub.local

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Daily backup time (24h HH:MM in server timezone)
BACKUP_TIME=03:00

# Wall display idle timeout (seconds before returning to clock)
WALL_IDLE_TIMEOUT_SECONDS=300
